local MainTab = Window:CreateTab("Main", 5012345678)

local MainSection = MainTab:CreateSection("Auto Features")

-- Auto Bonds Toggle
local AutoBondsEnabled = false

MainTab:CreateToggle({
    Name = "Auto Bonds",
    CurrentValue = false,
    Flag = "AutoBonds",
    Callback = function(Value)
        AutoBondsEnabled = Value
        
        if Value then
            print("[Auto Bonds] Enabled")

            -- Rail movement loop
            task.spawn(function()
                repeat task.wait() until game.Players.LocalPlayer.Character
                local root = game.Players.LocalPlayer.Character:WaitForChild("HumanoidRootPart")

                local velo = 1500
                local tRails = {}

                for _, obj in ipairs(workspace:WaitForChild("RailSegments"):GetDescendants()) do
                    if obj:IsA("BasePart") and obj.Name == "Guide" then
                        table.insert(tRails, obj)
                    end
                end

                local function pathway(pos)
                    local closest, dist = nil, math.huge
                    for _, rail in ipairs(tRails) do
                        local d = (rail.Position - pos).Magnitude
                        if d < dist then
                            dist = d
                            closest = rail
                        end
                    end
                    return closest
                end

                workspace.CurrentCamera.CameraType = Enum.CameraType.Scriptable

                local currentRail = pathway(root.Position)
                local currentPos = currentRail and currentRail.Position or root.Position

                local tVisited = {}
                local lastDirection = Vector3.new(0, 0, 1)

                while AutoBondsEnabled do
                    if currentRail then
                        tVisited[currentRail] = true
                        lastDirection = currentRail.CFrame.LookVector.Unit
                    end

                    local targetPos = currentPos - lastDirection * 20
                    local distance = (targetPos - currentPos).Magnitude
                    local duration = distance / velo
                    local start = tick()

                    while tick() - start < duration and AutoBondsEnabled do
                        local pos = currentPos:Lerp(targetPos, (tick() - start) / duration)

                        if root and root.Parent then
                            root.CFrame = CFrame.new(pos)
                        end

                        workspace.CurrentCamera.CFrame = CFrame.new(
                            pos + Vector3.new(0, 15, 0),
                            pos
                        )

                        game:GetService("RunService").RenderStepped:Wait()
                    end

                    if not AutoBondsEnabled then break end

                    currentPos = targetPos

                    local nextRail = nil
                    local bDot = 0.5

                    for _, rail in ipairs(tRails) do
                        if not tVisited[rail] then
                            local toRail = (rail.Position - currentPos).Unit
                            local dot = lastDirection:Dot(toRail)

                            if dot > bDot and (rail.Position - currentPos).Magnitude < 50 then
                                bDot = dot
                                nextRail = rail
                            end
                        end
                    end

                    currentRail = nextRail
                end

                -- Cleanup
                workspace.CurrentCamera.CameraType = Enum.CameraType.Custom
                print("[Auto Bonds] Rail movement stopped")
            end)

            -- Remote firing loop
            task.spawn(function()
                while AutoBondsEnabled do
                    for i = 1000, 1500 do
                        if not AutoBondsEnabled then break end
                        pcall(function()
                            game:GetService("ReplicatedStorage").Shared.Universe.Network.RemoteEvent.Actionable:FireServer(i)
                        end)
                        task.wait()
                    end
                    task.wait()
                end
            end)

            -- Auto reset character after 40 seconds
            task.delay(40, function()
                if AutoBondsEnabled and game.Players.LocalPlayer.Character then
                    game.Players.LocalPlayer.Character:BreakJoints()
                end
            end)

        else
            AutoBondsEnabled = false
            print("[Auto Bonds] Disabled")
            workspace.CurrentCamera.CameraType = Enum.CameraType.Custom
        end
    end
})

